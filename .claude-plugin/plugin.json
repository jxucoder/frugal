{
  "name": "frugal",
  "description": "Cost-reduction discipline for AI coding sessions. Minimizes turns and tokens through behavioral rules and compound learning from extracted skills.",
  "author": {
    "name": "Jiarui Xu",
    "url": "https://github.com/jxucoder"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/src/hooks/frugal-activate.js\"",
            "timeout": 5,
            "statusMessage": "Loading frugal mode..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/src/hooks/frugal-tracker.js\"",
            "timeout": 5,
            "statusMessage": "Tracking frugal mode..."
          }
        ]
      }
    ]
  }
}
